# ── PayPal ──────────────────────────────────────────────────────
# From developer.paypal.com → My Apps & Credentials
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# From developer.paypal.com → Webhooks (the webhook ID, NOT the URL)
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here

# "sandbox" for testing, "live" for production
PAYPAL_MODE=sandbox

# ── Supabase ─────────────────────────────────────────────────────
# From Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here   # ← NOT the anon key!

# ── Server ───────────────────────────────────────────────────────
PORT=3000
